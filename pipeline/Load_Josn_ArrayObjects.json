{
	"name": "Load_Josn_ArrayObjects",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFileName": "students.json",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['school']['name']"
								},
								"sink": {
									"name": "name"
								}
							},
							{
								"source": {
									"path": "$['school']['location']"
								},
								"sink": {
									"name": "location"
								}
							},
							{
								"source": {
									"path": "$['school']['students'][0]['id']"
								},
								"sink": {
									"name": "id",
									"type": "Int32"
								}
							},
							{
								"source": {
									"path": "$['school']['students'][0]['name']"
								},
								"sink": {
									"name": "name"
								}
							},
							{
								"source": {
									"path": "$['school']['students'][0]['subjects'][0]"
								},
								"sink": {
									"name": "subjects"
								}
							},
							{
								"source": {
									"path": "$['school']['teachers'][0]['id']"
								},
								"sink": {
									"name": "id",
									"type": "Int32"
								}
							},
							{
								"source": {
									"path": "$['school']['teachers'][0]['name']"
								},
								"sink": {
									"name": "name"
								}
							},
							{
								"source": {
									"path": "$['school']['teachers'][0]['classes'][0]"
								},
								"sink": {
									"name": "classes"
								}
							}
						]
					}
				},
				"inputs": [
					{
						"referenceName": "Json_inputdataset",
						"type": "DatasetReference",
						"parameters": {
							"foldername": "inputdata"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "sqldataset",
						"type": "DatasetReference",
						"parameters": {
							"tablename": "students_json"
						}
					}
				]
			}
		],
		"annotations": []
	}
}