{
	"name": "PL_LoadJson",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFileName": "*.json",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['firstname']"
								},
								"sink": {
									"name": "firstname",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['lastname']"
								},
								"sink": {
									"name": "lastname",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['village']"
								},
								"sink": {
									"name": "villege",
									"type": "String"
								}
							},
							{
								"source": {
									"path": "$['dob']"
								},
								"sink": {
									"name": "dob",
									"type": "Date"
								}
							}
						],
						"mapComplexValuesToString": true
					}
				},
				"inputs": [
					{
						"referenceName": "Json_inputdataset",
						"type": "DatasetReference",
						"parameters": {
							"foldername": "inputdata"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "sqldataset",
						"type": "DatasetReference",
						"parameters": {
							"tablename": "customer_json"
						}
					}
				]
			}
		],
		"annotations": []
	}
}