{
	"name": "storage_event_based trigger",
	"properties": {
		"annotations": [],
		"runtimeState": "Started",
		"pipelines": [
			{
				"pipelineReference": {
					"referenceName": "PL_storage-event-trigger",
					"type": "PipelineReference"
				},
				"parameters": {
					"foname": "@trigger().outputs.body.foldername",
					"fname": "@trigger().outputs.body.filename"
				}
			},
			{
				"pipelineReference": {
					"referenceName": "PL_sendemail",
					"type": "PipelineReference"
				},
				"parameters": {
					"foldername": "@trigger().outputs.body.folderPath",
					"filename": "@trigger().outputs.body.fileName"
				}
			}
		],
		"type": "BlobEventsTrigger",
		"typeProperties": {
			"blobPathBeginsWith": "/prasadcontainer/blobs/inputdata/emp*",
			"blobPathEndsWith": ".csv",
			"ignoreEmptyBlobs": true,
			"scope": "/subscriptions/a2802da5-d374-447e-840f-5a4261000cb7/resourceGroups/Prasad-Development/providers/Microsoft.Storage/storageAccounts/prasadstoragaccount",
			"events": [
				"Microsoft.Storage.BlobCreated"
			]
		}
	}
}